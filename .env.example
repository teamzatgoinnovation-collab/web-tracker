# ZatGo Next.js app — copy to .env.local (never commit secrets)
#
# Required in production:
#   ERPNEXT_SESSION_SECRET   long random string (openssl rand -base64 48)
#
# Local development (pick one):
#   ERPNEXT_SESSION_SECRET=<your-dev-secret>
#   OR ALLOW_INSECURE_DEV_SECRETS=1  (uses documented placeholder — NEVER in prod)

ERPNEXT_SESSION_SECRET=
ALLOW_INSECURE_DEV_SECRETS=1

# Optional default ERPNext URL shown on the login form
NEXT_PUBLIC_FRAPPE_BASE_URL=https://erp.zatgo.online
